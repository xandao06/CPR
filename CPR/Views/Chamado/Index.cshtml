@model IEnumerable<CPR.Models.Domain.Chamado>
@{
    ViewData["Title"] = "Chamados";
}
<div style="padding:40px" id="container" class="justify-content-between">
    <div>
        <h1 class="text-center mb-3">Chamados</h1>
        <div class="mb-4" style="display:flex;justify-content:space-between">
            <div>
                <a class="btn btn-outline-dark" data-bs-toggle="modal" data-bs-target="#modalCriarChamado">Criar um chamado</a>
                <a type="button" asp-controller="Cliente" asp-action="Index" class="btn btn-outline-dark">Clientes</a>
                <a type="button" asp-controller="Chamado" asp-action="Historico" class="btn btn-outline-dark">Histórico</a>
            </div>
            <div style="display:flex">
                <input type="text" id="Pesquisa" class="form-control" placeholder="Buscar">
            </div>
        </div>
    </div>
    <table class="table">
        <thead>
            <tr>
                <th>Data</th>
                <th>Hora</th>
                <th>Cliente</th>
                <th>Descrição</th>
                <th>Contrato</th>
                <th>Urgência</th>
                <th>Status</th>
                <th style="width:75px">Opções</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>08/07/2023</td>
                <td>17:53</td>
                <td>Cliente1</td>
                <td>Pinpad não funciona</td>
                <td>Sim</td>
                <td>Urgente</td>
                <td>Pendente</td>
                <td style="width:1px">
                    <a><i class="bi bi-check-square"></i></a>
                    <a data-bs-toggle="modal" data-bs-target="#modalEditarChamado">
                        <i class="bi-pencil-square"></i>
                    </a>
                    <a data-bs-toggle="modal" data-bs-target="#modalDelete">
                        <i class="bi bi-trash3-fill"></i>
                    </a>
                </td>
            </tr>
        </tbody>
    </table>
</div>
<partial name="~/Views/Shared/Delete.cshtml" />
<partial name="~/Views/Chamado/Modal/EditarChamado.cshtml" />
<partial name="~/Views/Chamado/Modal/CriarChamado.cshtml" />
