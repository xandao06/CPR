@model CPR.Models.Domain.Chamado

@{
    Layout = null;
}

<div id="modalConcluir" class="modal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-action="ConcluirChamado">
                <input asp-for="Id" type="hidden">
                <div class="modal-header">
                    <h5 class="modal-title">Concluir</h5>
                </div>
                <div class="modal-body">
                    <p>Tem certeza que deseja concluir esse chamado?</p>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-secondary" id="btnSim">Sim</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                </div>
            </form>
        </div>
    </div>
</div>