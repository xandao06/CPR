<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CPR</title>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css"/>
    <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">

</head>
<body id="bg">
    <header class="card-header">
        <div class="logo">
            <a asp-area="" asp-controller="Chamado" asp-action="ChamadoIndex">
                <img src="~/img/cpr.png" alt="Logo" style="width:100px" />
            </a>
        </div>
        <nav class=" nav mb-5 navbar-brand text-white justify-content-md-center d-flex">
            <div>
                <a class="btn btn-outline-dark me-1 mt-1" id="btn-CriarChamado" onclick="ModalCriarChamado()">Criar um chamado</a>
            </div>
            <div>
                <a type="button" asp-controller="Chamado" asp-action="RegistroIndex" class="btn btn-outline-dark mt-1">Registros</a>
            </div>
            <div>
                <a id="refresh" onclick="refreshPage()">
                    <img src="~/img/refresh.png" style="width:45px" />
                </a>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
        <div id="modalCPR"></div>
    </div>

    @* <footer class="footer text-muted">
        <div class="container">
            teste
       </div>
    </footer> *@
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/Script.js" asp-append-version="true"></script>
    <script src="~/js/RegistroScript.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
